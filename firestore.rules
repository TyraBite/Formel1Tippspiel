rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /events/{id}         { allow read: if request.auth != null; }
    match /drivers/{id}        { allow read: if request.auth != null; }
    match /session_results/{id}{ allow read: if request.auth != null; }
    match /scores/{id}         { allow read: if request.auth != null; }
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }
    match /tips/{tipId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.lockedAt != null
      );
      allow create: if request.auth.uid == request.resource.data.userId
        && request.resource.data.lockedAt == null;
      allow update: if request.auth.uid == resource.data.userId
        && resource.data.lockedAt == null;
    }
  }
}
